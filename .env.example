# ─── Alta Water Ad Generator — Environment Variables ───────────────────────
# Copy to .env and fill in values before running.

# ElevenLabs — get from 1Password
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# Optional: override default voice (Rachel = 21m00Tcm4TlvDq8ikWAM)
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Runway — get from 1Password
RUNWAY_API_KEY=your_runway_api_key_here
# RUNWAY_MODEL=gen4_turbo
# RUNWAY_CLIP_DURATION=5
# RUNWAY_SCENES_PER_AD=4

# Google Drive — service account JSON (stringify the entire JSON as one line)
# Use: cat service-account-key.json | jq -c . | pbcopy
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# Parent folder ID from Google Drive URL (the folder where all ads go)
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id

# Alta Water Dashboard (for /publish endpoint)
DASHBOARD_URL=https://altawater-dashboard-production.up.railway.app
METRICS_SECRET=altawater-metrics-2026

# Server
PORT=3000
TEMP_DIR=/tmp/altawater-ads
